# Collector runtime configuration
PORT=8787
HOST=0.0.0.0

# REQUIRED: bearer secret required by /v1/gold-silver-ratio.
# Must match TRADINGVIEW_COLLECTOR_API_TOKEN in the main app.
COLLECTOR_API_TOKEN=change-me-to-a-strong-random-value

# TradingView symbol (do not change unless you know what you are doing)
TRADINGVIEW_SYMBOL=TVC:GOLDSILVER

# Freshness thresholds (ms)
TRADINGVIEW_RATIO_STALE_AFTER_MS=120000
TRADINGVIEW_RATIO_UNAVAILABLE_AFTER_MS=600000

# Reconnection tuning
RECONNECT_BASE_MS=1000
RECONNECT_MAX_MS=60000

# Rate limiter (requests per minute per IP for /v1/*)
RATE_LIMIT_PER_MIN=60

# Bounded response body size for outbound proxies (bytes)
MAX_RESPONSE_BYTES=4096